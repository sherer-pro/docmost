		{
			"name": "01 - API Keys Management (owner/admin session required)",
			"item": [
				{
					"name": "List API Keys (own)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"limit\": 20,\n  \"query\": \"\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api-keys",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api-keys"
							]
						},
						"description": "List current user's API keys."
					},
					"response": []
				},
				{
					"name": "List API Keys (workspace/adminView)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const payload = pm.response.json();",
									"const items = payload?.data?.items || [];",
									"if (items.length > 0) {",
									"  const first = items[0];",
									"  if (first.id) pm.collectionVariables.set('createdApiKeyId', first.id);",
									"  if (first.spaceId) pm.collectionVariables.set('spaceId', first.spaceId);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"limit\": 20,\n  \"adminView\": true,\n  \"query\": \"\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api-keys",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api-keys"
							]
						},
						"description": "List all workspace API keys. Useful to auto-fill createdApiKeyId and spaceId."
					},
					"response": []
				},
				{
					"name": "Create API Key (No expiration)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const payload = pm.response.json();",
									"const data = payload?.data || payload;",
									"if (data?.id) pm.collectionVariables.set('createdApiKeyId', data.id);",
									"if (data?.token) {",
									"  pm.collectionVariables.set('createdApiKeyToken', data.token);",
									"  pm.collectionVariables.set('ragApiKey', data.token);",
									"}",
									"if (data?.spaceId) pm.collectionVariables.set('spaceId', data.spaceId);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"{{apiKeyName}}\",\n  \"spaceId\": \"{{spaceId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api-keys/create",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api-keys",
								"create"
							]
						},
						"description": "Creates a space-scoped API key and stores token into collection variable ragApiKey."
					},
					"response": []
				},
				{
					"name": "Update API Key Name",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"apiKeyId\": \"{{createdApiKeyId}}\",\n  \"name\": \"{{apiKeyName}} (renamed)\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api-keys/update",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api-keys",
								"update"
							]
						},
						"description": "Rename an existing API key."
					},
					"response": []
				},
				{
					"name": "Revoke API Key",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"apiKeyId\": \"{{createdApiKeyId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api-keys/revoke",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api-keys",
								"revoke"
							]
						},
						"description": "Soft-delete (revoke) API key."
					},
					"response": []
				}
			],
			"description": "These endpoints use regular authenticated session/JWT and return envelope response { data, success, status }."
		},
		{
			"name": "02 - RAG API (Bearer API key required)",
			"item": [
				{
					"name": "GET /rag/pages",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"const items = Array.isArray(res?.items) ? res.items : [];",
									"const firstDoc = items.find((x) => x?.id);",
									"if (firstDoc) {",
									"  pm.collectionVariables.set('pageIdOrSlug', firstDoc.slugId || firstDoc.id);",
									"}",
									"const firstDb = items.find((x) => x?.type === 'database');",
									"if (firstDb) {",
									"  pm.collectionVariables.set('databaseIdOrPageSlug', firstDb.databaseId || firstDb.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{ragApiKey}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/rag/pages?includeContent={{includeContent}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"rag",
								"pages"
							],
							"query": [
								{
									"key": "includeContent",
									"value": "{{includeContent}}"
								}
							]
						},
						"description": "Full list of active page|database in the scoped space."
					},
					"response": []
				},
