									"const res = pm.response.json();",
									"const items = Array.isArray(res?.items) ? res.items : [];",
									"if (items.length > 0) {",
									"  const file = items[0];",
									"  if (file.fileId || file.id) pm.collectionVariables.set('fileId', file.fileId || file.id);",
									"  if (file.fileName) pm.collectionVariables.set('fileName', file.fileName);",
									"}"
